generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Interview{
  id                  String          @id @default(uuid())
  githubMetadata      Json
  status              InterviewStatus
  score               Int             @default(0)
  messages            Message[]

}

model Message{
  id                  String          @id @default(uuid())
  message             String
  type                MessageType
  interviewId         String
  interview           Interview       @relation(fields: [interviewId], references: [id])
}

enum MessageType{
  User
  Assistant
}

enum InterviewStatus{
  Pre
  InProgress
  Done
}